# Environment for tonnode-mcp --http.  Keep this file mode 600.
# sudo cp deploy/tonnode-mcp.env /etc/tonnode-mcp.env && sudo chmod 600 /etc/tonnode-mcp.env

# Bind only to localhost — Caddy terminates TLS and proxies to us.
HOST=127.0.0.1
PORT=8808

# Customer keys: JSON file, hot-reloaded on change / SIGHUP.
# Manage with deploy/tonnode-keys.sh (add/revoke/list, per-key rpm, expiry).
TONNODE_KEYS_FILE=/etc/tonnode-mcp.keys.json

# Alternative (simple mode): fixed comma-separated keys instead of the file.
#   Generate: echo "tn_live_$(openssl rand -hex 24)"
# TONNODE_KEYS=tn_live_replace_me

# Default requests-per-minute per key (a key's "rpm" field overrides this).
RATE_LIMIT_RPM=300

# Total ceiling across ALL keys — protects the backend liteserver no matter
# how many customers there are. 600/min = 10 rps sustained. 0 = disabled.
GLOBAL_RATE_LIMIT_RPM=600

# Point at your own liteserver instead of the public config.
# On the node itself use 127.0.0.1 and the liteserver port + base64 key
# from your node's local config (mytonctrl: /usr/bin/ton/local.config.json).
# TON_LITESERVERS=[{"ip":"1.2.3.4","port":40004,"key":"BASE64_LITESERVER_PUBKEY"}]
